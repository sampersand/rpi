def p(x)
	printf($stderr, "%s\n", x._inspect); $stderr.flush
end

def system_e(cmd)
	ret = system(cmd)
	if $? != 0 then
		fail(sprintf("system call %s failed with code %d", cmd._inspect, $?))
	end
	ret
end

def system2_e(cmd)
	ret = system2(cmd)
	if $? != 0 then
		fail(sprintf("system call %s failed with code %d", cmd._inspect, $?))
	end
	ret
end

