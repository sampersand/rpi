#!/usr/bin/env r49


$ENV['DEBUG'] && $DEBUG = 1
$METHOD = $ENV['METHOD']


if $METHOD == 'POST' then
  load('extract-url-encoding.r49')
end

if $METHOD != 'POST' && $METHOD != 'GET' then
  system('status 405 true')
  exit()
end

system('status 200')
system('header Content-Type text/html')

print('<!DOCTYPE html>
<html>
<body>
  <form method="POST">
    <label for="code">Code:</label><br>
    <textarea id="code" name="code" rows="5" cols="40">' + ($code || 'print(1+2)') + '</textarea><br><br>

    <input type="checkbox" id="include_stderr" name="include_stderr" value="true">
    <label for="include_stderr">Include stderr</label><br><br>

    <input type="submit" value="Submit">
  </form>')

if $METHOD == 'POST' then
  print("<pre><code>\n")

  print("--response--\n")
  setenv('_code', $code)
  system(':; r49 2>&1 -e "$_code"')
  printf("\n--exit code--\n%d\n", $? >> 8)
  print("</code></pre>\n")
end

print("  </body>\n<html>")
